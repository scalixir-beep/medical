APP_NAME="EPS2 Dossier Patient"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=sqlite
# DB_DATABASE= laisser vide = database/database.sqlite (chemin relatif auto)

# API token-based → pas besoin de sessions en base
SESSION_DRIVER=file

SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000

# Production : remplacer * par l'URL exacte du frontend
# CORS_ALLOWED_ORIGINS=https://mon-frontend.com
CORS_ALLOWED_ORIGINS=*

# Google OAuth (Socialite)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_URL=http://localhost:5173

# Swagger / OpenAPI
L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_UI_DOC_EXPANSION=list
